APP_ENV=dev
HOST=0.0.0.0
PORT=8000

USE_MOCK_LLM=true
USE_MOCK_TTS=true

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

TTS_TARGET_MIN_SECONDS=40
TTS_TARGET_MAX_SECONDS=55
TTS_CHARS_PER_MINUTE=240
TTS_PAUSE_MS=180

COVER_WIDTH=1080
COVER_HEIGHT=1440

XULAN_ASSET_PATH=assets/xulan/xulan_main.png

# Optional: copy final audio and cover into an external folder after each job.
MEDIA_EXPORT_DIR=

# Optional replaceable LLM HTTP provider. Keep empty to use mock LLM.
LLM_API_URL=
LLM_API_KEY=
LLM_MODEL=
